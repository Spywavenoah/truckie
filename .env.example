# App
NODE_ENV=production
APP_URL=https://yourapp.com
JWT_SECRET=
JWT_REFRESH_SECRET=
SESSION_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://yourapp.com

# Database (Neon PostgreSQL)
# The DATABASE_URL is automatically provided by the Neon integration
# For local development, you can set it manually or use: npm run db:pull
DATABASE_URL=postgresql://user:password@neon.tech/truckie

# Redis (Optional)
REDIS_URL=redis://localhost:6379

# Monnify
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_BASE_URL=https://api.monnify.com
MONNIFY_WEBHOOK_SECRET=
MONNIFY_PLATFORM_ACCOUNT=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email
SENDGRID_API_KEY=
EMAIL_FROM=noreply@yourapp.com

# SMS (Termii)
TERMII_API_KEY=
TERMII_SENDER_ID=

# 2FA
TOTP_ISSUER=TruckLeasePro
